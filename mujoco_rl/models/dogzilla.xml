<mujoco model="dogzilla">
  <!--
    Hand-authored from yahboomcar_ws/src/yahboom_description/urdf/yahboom_xgo_rviz.xacro
    (geometry, meshes, inertials) combined with DOGZILLALib.PARAM["MOTOR_LIMIT"] (real
    servo angle limits in degrees: hip [-73,57], upper [-66,93], lower [-31,31]) since the
    xacro's own joint limits are unfilled +-pi placeholders, not the real hardware range.

    Joint naming mirrors DOGZILLALib motor ids (x1=hip/lower-limit, x2=upper leg/middle-limit,
    x3=lower leg/upper-limit) so sim actions map 1:1 onto DOGZILLALib.motor(motor_id, angle_deg)
    at deployment time.
  -->
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast"/>

  <default>
    <default class="dogzilla">
      <geom contype="1" conaffinity="1" condim="3" friction="0.8 0.02 0.01" solref="0.005 1" margin="0.001"/>
      <joint damping="0.3" armature="0.005" frictionloss="0.02"/>
      <position kp="6" kv="0.3" forcerange="-3 3"/>
      <default class="hip">
        <joint range="-1.27409 0.99484"/>
        <position ctrlrange="-1.27409 0.99484"/>
      </default>
      <default class="upper">
        <joint range="-1.15192 1.62316"/>
        <position ctrlrange="-1.15192 1.62316"/>
      </default>
      <default class="lower">
        <joint range="-0.54105 0.54105"/>
        <position ctrlrange="-0.54105 0.54105"/>
      </default>
    </default>
  </default>

  <asset>
    <material name="body_grey" rgba="0.529 0.549 0.549 1"/>
    <material name="leg_grey" rgba="0.898 0.918 0.929 1"/>
    <texture type="2d" name="grid" builtin="checker" rgb1="0.2 0.25 0.3" rgb2="0.25 0.3 0.35" width="300" height="300"/>
    <material name="floor" texture="grid" texrepeat="5 5" reflectance="0.1"/>

    <mesh name="base_link" file="base_link.STL"/>
    <mesh name="lf_hip_link" file="lf_hip_link.STL"/>
    <mesh name="lf_upper_leg_link" file="lf_upper_leg_link.STL"/>
    <mesh name="lf_lower_leg_link" file="lf_lower_leg_link.STL"/>
    <mesh name="rf_hip_link" file="rf_hip_link.STL"/>
    <mesh name="rf_upper_leg_link" file="rf_upper_leg_link.STL"/>
    <mesh name="rf_lower_leg_link" file="rf_lower_leg_link.STL"/>
    <mesh name="lh_hip_link" file="lh_hip_link.STL"/>
    <mesh name="lh_upper_leg_link" file="lh_upper_leg_link.STL"/>
    <mesh name="lh_lower_leg_link" file="lh_lower_leg_link.STL"/>
    <mesh name="rh_hip_link" file="rh_hip_link.STL"/>
    <mesh name="rh_upper_leg_link" file="rh_upper_leg_link.STL"/>
    <mesh name="rh_lower_leg_link" file="rh_lower_leg_link.STL"/>
  </asset>

